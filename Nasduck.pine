//@version=5
indicator("NASDUCK Reddit Indicator Set", overlay=true)

// --- INPUTS ---
signalLen = input.int(9,  "Signal EMA (Fast)")
trendLen  = input.int(21, "Trend EMA (Slow)")
volLen    = input.int(20, "Volume MA Length")

//rsiLen    = input.int(14, "Momentum (RSI) Length")
//adxLen    = input.int(14, "ADX / DMI Length")
//adxThresh = input.int(25, "ADX Trend Strength Threshold")

// --- CALCULATIONS ---
emaSignal = ta.ema(close, signalLen)
emaTrend  = ta.ema(close, trendLen)
//rsiVal    = ta.rsi(close, rsiLen)

//[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)

//trendStrong = adxVal > adxThresh

volMA        = ta.sma(volume, volLen)
volConfirmed = volume > volMA

useVwap  = timeframe.in_seconds() < timeframe.in_seconds("1D")
vwapVal  = ta.vwap(close)
aboveVwap = not useVwap or close > vwapVal
belowVwap = not useVwap or close < vwapVal

// Nasduck Logic: Cross + Momentum + ADX/DMI Confirmation
longCondition  = ta.crossover(emaSignal, emaTrend)  and aboveVwap //and rsiVal > 50 and trendStrong and diPlus  > diMinus
shortCondition = ta.crossunder(emaSignal, emaTrend) and belowVwap //and rsiVal < 50 and trendStrong and diMinus > diPlus

// --- PIVOT POINTS ---
prevHigh  = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_on)
prevLow   = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_on)
prevClose = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_on)

pp = (prevHigh + prevLow + prevClose) / 3
r1 = (2 * pp) - prevLow
r2 = pp + (prevHigh - prevLow)
s1 = (2 * pp) - prevHigh
s2 = pp - (prevHigh - prevLow)

newDay = ta.change(time("D"))

pivotLine(level, col, txt) =>
    if newDay
        line.delete(line.new(bar_index, level, bar_index, level))
    if barstate.islast
        ln = line.new(bar_index - 500, level, bar_index, level, extend=extend.right, color=col, width=1, style=line.style_dashed)
        label.new(bar_index, level, txt + " " + str.tostring(level, format.mintick), style=label.style_label_left, color=color.new(col, 70), textcolor=color.white, size=size.tiny)

pivotLine(pp, color.yellow, "PP")
pivotLine(r1, color.red,    "R1")
pivotLine(r2, color.red,    "R2")
pivotLine(s1, color.green,  "S1")
pivotLine(s2, color.green,  "S2")

// --- VISUALS ---
// Plotting the "Ribbon"
p1 = plot(emaSignal, "Fast EMA", color=color.new(color.aqua, 0),   linewidth=2)
p2 = plot(emaTrend,  "Slow EMA", color=color.new(color.orange, 0), linewidth=2)

// Fill the space between EMAs to show trend strength
fillColor = emaSignal > emaTrend ? color.new(color.green, 85) : color.new(color.red, 85)
fill(p1, p2, fillColor, title="Trend Ribbon")

// VWAP line (intraday only)
plot(useVwap ? vwapVal : na, "VWAP", color=color.new(color.purple, 0), linewidth=1)

// Signal Plots
plotshape(longCondition,  style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.small, title="NASDUCK Buy")
plotshape(shortCondition, style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.small, title="NASDUCK Sell")

if longCondition
    label.new(bar_index, high, "BUY ▲ " + str.tostring(close, format.mintick), style=label.style_label_down, color=color.new(color.green, 80), textcolor=color.white, size=size.small)
if shortCondition
    label.new(bar_index, high, "SELL ▼ " + str.tostring(close, format.mintick), style=label.style_label_down, color=color.new(color.red,   80), textcolor=color.white, size=size.small)

// Volume confirmation dot
plotshape(volConfirmed, style=shape.circle, location=location.bottom, color=color.new(color.teal, 40), size=size.tiny, title="Volume Confirmed", text="V")

// Background "Heat" (Current State)
bgcolor(emaSignal > emaTrend ? color.new(color.green, 95) : color.new(color.red, 95))

// ADX / DMI plots (separate pane values shown as labels on chart)
//plotshape(trendStrong and diPlus  > diMinus, style=shape.circle, location=location.belowbar, color=color.new(color.green, 60), size=size.tiny, title="+DI Dominant")
//plotshape(trendStrong and diMinus > diPlus,  style=shape.circle, location=location.abovebar, color=color.new(color.red, 60),   size=size.tiny, title="-DI Dominant")
