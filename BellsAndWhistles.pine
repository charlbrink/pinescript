//@version=5
indicator("Bells and Whistles Indicator Set", overlay=true)

// --- INPUTS ---
signalLen = input.int(9,  "Signal EMA (Fast)")
trendLen  = input.int(21, "Trend EMA (Slow)")
volLen    = input.int(20, "Volume MA Length")
atrMult    = input.float(2.0, "ATR Stop Multiplier", step=0.5)
lightTheme = input.bool(false, "Light Theme")
showMFI    = input.bool(true,  "Show MFI Diamonds")
showADX    = input.bool(true,  "Show ADX/DMI Dots")
showDMI    = input.bool(true,  "Show DMI Crossovers")

// --- CALCULATIONS ---
emaSignal = ta.ema(close, signalLen)
emaTrend  = ta.ema(close, trendLen)
rsi       = ta.rsi(close, 14)
mfi       = ta.mfi(hlc3, 14)
[macdLine, macdSignal, macdHist] = ta.macd(close, 12, 26, 9)

// ADX / DMI
[diPlus, diMinus, adx] = ta.dmi(14, 14)
adxTrending  = adx > 25
adxBullish   = adxTrending and diPlus > diMinus
adxBearish   = adxTrending and diMinus > diPlus
dmiCrossUp   = ta.crossover(diPlus,  diMinus) and adxTrending
dmiCrossDown = ta.crossunder(diPlus, diMinus) and adxTrending

// OBV
obv            = ta.obv
obvHigh        = ta.highest(obv, 20)
priceMadeHigh  = close >= ta.highest(close, 20)
obvDivBearish  = priceMadeHigh and obv < obvHigh[1]

// ATR Stop Loss (daily)
atrDaily = request.security(syminfo.tickerid, "D", ta.atr(14))
atrStop  = atrDaily * atrMult

// Bollinger Bands
[bbMid, bbUpper, bbLower] = ta.bb(close, 20, 2)

volMA        = ta.sma(volume, volLen)
volConfirmed = volume > volMA

useVwap  = timeframe.in_seconds() < timeframe.in_seconds("1D")
vwapVal  = ta.vwap(close)
aboveVwap = not useVwap or close > vwapVal
belowVwap = not useVwap or close < vwapVal

labelTxtColor = lightTheme ? color.black : color.white

crossUp   = ta.crossover(emaSignal, emaTrend)
crossDown = ta.crossunder(emaSignal, emaTrend)

// Both RSI and MACD must confirm
macdLong  = macdLine > macdSignal and macdHist > 0
macdShort = macdLine < macdSignal and macdHist < 0

// Strong only when RSI + MFI + MACD confirm AND no OBV bearish divergence
mfiOverbought  = mfi > 80
longCondition  = crossUp   and rsi > 50 and mfi > 50 and macdLong  and not obvDivBearish and not mfiOverbought
shortCondition = crossDown and rsi < 50 and mfi < 50 and macdShort

// Weak — RSI/MFI/MACD fail, OBV divergence, or MFI overbought caution
weakLong  = crossUp   and not (rsi > 50 and mfi > 50 and macdLong) or (crossUp and obvDivBearish) or (crossUp and mfiOverbought)
weakShort = crossDown and not (rsi < 50 and mfi < 50 and macdShort)

// --- PIVOT POINTS ---
prevHigh  = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_on)
prevLow   = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_on)
prevClose = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_on)

pp = (prevHigh + prevLow + prevClose) / 3
r1 = (2 * pp) - prevLow
r2 = pp + (prevHigh - prevLow)
s1 = (2 * pp) - prevHigh
s2 = pp - (prevHigh - prevLow)

newDay = ta.change(time("D"))

pivotLine(level, col, txt) =>
    if newDay
        line.delete(line.new(bar_index, level, bar_index, level))
    if barstate.islast
        ln = line.new(bar_index - 500, level, bar_index, level, extend=extend.right, color=col, width=1, style=line.style_dashed)
        label.new(bar_index, level, txt + " " + str.tostring(level, format.mintick), style=label.style_label_left, color=color.new(col, 70), textcolor=labelTxtColor, size=size.tiny)

pivotLine(pp, color.yellow, "PP")
pivotLine(r1, color.red,    "R1")
pivotLine(r2, color.red,    "R2")
pivotLine(s1, color.green,  "S1")
pivotLine(s2, color.green,  "S2")

// --- VISUALS ---
// Plotting the "Ribbon"
p1 = plot(emaSignal, "Fast EMA", color=color.new(color.aqua, 0),   linewidth=2)
p2 = plot(emaTrend,  "Slow EMA", color=color.new(color.orange, 0), linewidth=2)

// Fill the space between EMAs to show trend strength
fillColor = emaSignal > emaTrend ? color.new(color.green, 65) : color.new(color.red, 65)
fill(p1, p2, fillColor, title="Trend Ribbon")

// Bollinger Bands
plot(bbUpper, "BB Upper", color=color.silver, linewidth=1, style=plot.style_line)
plot(bbMid,   "BB Mid",   color=color.yellow, linewidth=1, style=plot.style_line)
plot(bbLower, "BB Lower", color=color.silver, linewidth=1, style=plot.style_line)

// VWAP line (intraday only)
plot(useVwap ? vwapVal : na, "VWAP", color=color.new(color.purple, 0), linewidth=1)

// Signal Plots
plotshape(longCondition,  style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.small, title="Buy")
plotshape(shortCondition, style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.small, title="Sell")
plotshape(weakLong,       style=shape.triangleup,   location=location.belowbar, color=color.gray,  size=size.small, title="Weak Buy")
plotshape(weakShort,      style=shape.triangledown, location=location.abovebar, color=color.gray,  size=size.small, title="Weak Sell")

// ATR stop levels — persist until next signal
var float slLongLevel  = na
var float slShortLevel = na

if longCondition
    slLongLevel  := close - atrStop
    slShortLevel := na
    line.new(bar_index, slLongLevel,  bar_index + 5, slLongLevel,  color=color.red,   width=2, style=line.style_dashed)
if shortCondition
    slShortLevel := close + atrStop
    slLongLevel  := na
    line.new(bar_index, slShortLevel, bar_index + 5, slShortLevel, color=color.green, width=2, style=line.style_dashed)

if longCondition
    label.new(bar_index, high, "BUY ▲ " + str.tostring(close, format.mintick) + "  SL: " + str.tostring(slLongLevel, format.mintick), style=label.style_label_down, color=color.new(color.green, 80), textcolor=labelTxtColor, size=size.small)
if shortCondition
    label.new(bar_index, high, "SELL ▼ " + str.tostring(close, format.mintick) + "  SL: " + str.tostring(slShortLevel, format.mintick), style=label.style_label_down, color=color.new(color.red, 80), textcolor=labelTxtColor, size=size.small)
if weakLong
    cautionTxt = mfiOverbought ? "CAUTION ▲" : "WEAK ▲"
    label.new(bar_index, low,  cautionTxt + " " + str.tostring(close, format.mintick), style=label.style_label_up,   color=color.new(color.gray, 70), textcolor=labelTxtColor, size=size.tiny)
if weakShort
    label.new(bar_index, high, "WEAK ▼ "   + str.tostring(close, format.mintick), style=label.style_label_down, color=color.new(color.gray, 70), textcolor=labelTxtColor, size=size.tiny)

plot(slLongLevel,  "SL Long",  color=na)
plot(slShortLevel, "SL Short", color=na)

// Volume confirmation dot
plotshape(volConfirmed, style=shape.circle, location=location.bottom, color=color.new(color.teal, 40), size=size.tiny, title="Volume Confirmed", text="V")

// VWAP bias — always visible, independent of signal
vwapBiasColor = useVwap ? (close > vwapVal ? color.new(color.green, 20) : color.new(color.red, 20)) : color.new(color.gray, 60)
plotshape(true, style=shape.circle,  location=location.top,      color=vwapBiasColor,                size=size.tiny,  title="VWAP Bias")

// MFI bias diamond — below the candle
mfiDotColor = mfi > 80 ? color.new(color.orange, 20) : mfi > 50 ? color.new(color.green, 20) : color.new(color.red, 20)
plotshape(showMFI, style=shape.diamond, location=location.belowbar, color=mfiDotColor, size=size.tiny, title="MFI Bias")

// ADX/DMI — Option 1: directional strength dot
adxDotColor = adxBullish ? color.new(color.green, 20) : adxBearish ? color.new(color.red, 20) : color.new(color.gray, 40)
plotshape(showADX, style=shape.circle, location=location.abovebar, color=adxDotColor, size=size.tiny, title="ADX/DMI Bias")

// ADX/DMI — Option 3: +DI/-DI crossover xcross (only when ADX > 25)
plotshape(showDMI and dmiCrossUp,   style=shape.xcross, location=location.belowbar, color=color.new(color.green, 20), size=size.small, title="DMI Cross Up")
plotshape(showDMI and dmiCrossDown, style=shape.xcross, location=location.abovebar, color=color.new(color.red,   20), size=size.small, title="DMI Cross Down")

// ADX/DMI — Option 4: live ADX readout label
if barstate.islast
    adxLabelColor = adx > 25 ? color.green : adx > 20 ? color.yellow : color.red
    label.new(bar_index + 2, high, "ADX: " + str.tostring(adx, "#.0"), style=label.style_label_left, color=color.new(adxLabelColor, 70), textcolor=color.white, size=size.tiny)

// Background "Heat" (Current State)
bgcolor(emaSignal > emaTrend ? color.new(color.green, 95) : color.new(color.red, 95))
